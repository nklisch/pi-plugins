{
  "name": "@nklisch/pi-plugin-host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node --run clean:dist",
    "clean:dist": "node -e \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "boundaries": "depcruise src --config .dependency-cruiser.cjs",
    "test:unit": "vitest run",
    "test:package": "npm run build && node test/compiled-package-import.mjs",
    "test": "npm run typecheck && npm run boundaries && npm run test:unit && npm run test:package"
  },
  "dependencies": {
    "semver": "7.8.1",
    "smol-toml": "^1.7.0",
    "yaml": "2.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.8",
    "@swc/core": "^1.15.43",
    "@types/node": "^24.0.0",
    "dependency-cruiser": "^17.0.0",
    "typescript": ">=7.0.0 <8",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  }
}
